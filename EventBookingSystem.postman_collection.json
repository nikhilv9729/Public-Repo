                  "pm.test('Status is 409 Conflict', () => pm.response.to.have.status(409));",
                  "pm.test('Error message mentions re-book', () => pm.expect(pm.response.json().message).to.include('already'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/bookings", "host": ["{{baseUrl}}"], "path": ["api","bookings"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": {{eventId}},\n  \"numberOfTickets\": 1\n}"
            }
          }
        },

        {
          "name": "❌ Book Tickets - Exceed Capacity (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400 Bad Request', () => pm.response.to.have.status(400));",
                  "pm.test('Error mentions seats', () => pm.expect(pm.response.json().message).to.include('seats'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/bookings", "host": ["{{baseUrl}}"], "path": ["api","bookings"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": {{eventId}},\n  \"numberOfTickets\": 99999\n}"
            }
          }
        },

        {
          "name": "❌ Book Tickets - No Auth (expect 403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 403 Forbidden', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/bookings", "host": ["{{baseUrl}}"], "path": ["api","bookings"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": {{eventId}},\n  \"numberOfTickets\": 1\n}"
            }
          }
        },

        {
          "name": "Cancel Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status is 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Booking status is CANCELLED', () => pm.expect(res.status).to.eql('CANCELLED'));",
                  "pm.test('Booking ID matches', () => pm.expect(res.id.toString()).to.eql(pm.collectionVariables.get('bookingId')));",
                  "console.log('✅ Booking cancelled, seats restored to event');"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/cancel", "host": ["{{baseUrl}}"], "path": ["api","bookings","{{bookingId}}","cancel"] }
          }
        },

        {
          "name": "❌ Cancel Already-Cancelled Booking (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400 Bad Request', () => pm.response.to.have.status(400));",
                  "pm.test('Error says already cancelled', () => pm.expect(pm.response.json().message).to.include('already cancelled'));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/cancel", "host": ["{{baseUrl}}"], "path": ["api","bookings","{{bookingId}}","cancel"] }
          }
        }

      ]
    }

  ]
