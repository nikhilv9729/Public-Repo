{
  "info": {
    "name": "Event Booking System",
    "description": "Complete API collection for the Event Booking System. \n\n**Setup:**\n1. Start the Spring Boot app on localhost:8080\n2. Run 'Register Organizer' → token auto-saved\n3. Run 'Register Customer' → token auto-saved\n4. All subsequent requests use saved tokens automatically\n\n**Flow:**\nRegister → Login → Create Event → Browse Events → Book Tickets → View Bookings → Cancel",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",        "value": "http://localhost:8080",  "type": "string" },
    { "key": "organizerToken", "value": "",                       "type": "string" },
    { "key": "customerToken",  "value": "",                       "type": "string" },
    { "key": "eventId",        "value": "",                       "type": "string" },
    { "key": "bookingId",      "value": "",                       "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 Auth",
      "item": [

        {
          "name": "Register Organizer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status is 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Token is present', () => pm.expect(res.token).to.be.a('string').and.not.empty);",
                  "pm.test('Role is ORGANIZER', () => pm.expect(res.role).to.eql('ORGANIZER'));",
                  "pm.test('Email matches', () => pm.expect(res.email).to.eql('alice@eventbooking.com'));",
                  "pm.collectionVariables.set('organizerToken', res.token);",
                  "console.log('✅ Organizer token saved');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Organizer\",\n  \"email\": \"alice@eventbooking.com\",\n  \"password\": \"secret123\",\n  \"role\": \"ORGANIZER\"\n}"
            }
          }
        },

